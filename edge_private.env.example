# Edge private environment example (safe template)
EXTERNAL_BASE=https://your-cloud-public-host
EXTERNAL_API_KEY=replace-with-cloud-internal-api-key
EXTERNAL_SIGNING_SECRET=replace-with-cloud-internal-signing-secret

EDGE_AUTH_TOKEN=replace-with-strong-random-token
LINE_CHANNEL_ACCESS_TOKEN=replace-with-line-channel-access-token
LINE_PUSH_API=https://api.line.me/v2/bot/message/push
LINE_API_TIMEOUT_SEC=10

RUN_BACKGROUND_WORKERS=1
EDGE_ALLOWED_IPS=
EDGE_AUTH_RATE_LIMIT=20
EDGE_AUTH_RATE_WINDOW_SEC=600
EDGE_TRUST_PROXY_HEADERS=0
EDGE_TRUSTED_PROXY_IPS=
EDGE_TRUST_X_FORWARDED_FOR=0
EDGE_COOKIE_SECURE=1
EDGE_COOKIE_MAX_AGE_SEC=28800

SYNC_EMPTY_SLEEP_SEC=5
SYNC_ERROR_SLEEP_SEC=10
SYNC_HEARTBEAT_INTERVAL_SEC=30
RECONCILE_INTERVAL_SEC=30
LINE_RETRY_INTERVAL_SEC=60
LINE_MAX_RETRY_COUNT=10

MAX_IMAGE_BYTES=8388608
MAX_NOTE_CHARS=800
MAX_AI_SUGGESTION_CHARS=1200

DIAPER_DETECTOR_MODEL_PATH=models/yolo_best_step1.pt
LESION_DETECTOR_MODEL_PATH=models/yolo_best_step2.pt
SEVERITY_CLASSIFIER_MODEL_PATH=models/efficientnet_best.pth

DIAPER_DETECT_CONF_THRESHOLD=0.25
LESION_DETECT_CONF_THRESHOLD=0.25
MIN_CROP_SIZE_PX=10

DIAPER_NOT_FOUND_MESSAGE=Unable to detect diaper region, please retake the photo.
LESION_NOT_FOUND_MESSAGE=No clear lesion detected, please retake the photo or continue monitoring.
AI_FAILED_MESSAGE=AI inference failed, please wait for clinician manual review.
